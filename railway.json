{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE"
  },
  "services": {
    "bot": {
      "buildConfig": {
        "dockerfilePath": "packages/bot/Dockerfile",
        "buildContext": "."
      },
      "deploy": {
        "startCommand": "node packages/bot/dist/index.js",
        "healthcheckPath": "/health",
        "restartPolicyType": "ON_FAILURE"
      },
      "variables": {
        "BOT_MODE": "polling",
        "ORCHESTRATOR_URL": "http://${{orchestrator.RAILWAY_PRIVATE_DOMAIN}}:3001"
      }
    },
    "orchestrator": {
      "buildConfig": {
        "dockerfilePath": "packages/orchestrator/Dockerfile",
        "buildContext": "."
      },
      "deploy": {
        "startCommand": "node packages/orchestrator/dist/index.js",
        "restartPolicyType": "ON_FAILURE"
      },
      "variables": {
        "PORT": "3001"
      }
    }
  }
}
