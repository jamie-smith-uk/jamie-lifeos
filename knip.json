{
  "$schema": "https://unpkg.com/knip@6.5.0/schema.json",
  "workspaces": {
    "packages/bot": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/orchestrator": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/shared": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    }
  },
  "ignore": [
    "pipeline/**",
    "dist/**",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.config.ts"
  ],
  "ignoreDependencies": [
    "@lifeos/shared"
  ]
}
